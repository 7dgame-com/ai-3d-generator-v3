{
  "// 说明": "此文件为插件注册配置示例，将内容添加到主系统的 plugins.json 中",
  "// id": "插件唯一标识符，建议使用英文小写+连字符",
  "// name": "插件默认显示名称",
  "// nameI18n": "多语言名称，key 为语言代码",
  "// url": "插件访问地址（Docker 部署后的地址）",
  "// icon": "Element Plus 图标名称",
  "// group": "插件分组，可选值：tools、education、management 等",
  "// enabled": "是否启用",
  "// order": "排序权重，数字越小越靠前",
  "// allowedOrigin": "允许的跨域来源（用于 postMessage 安全校验）",
  "// version": "插件版本号",
  "// 注意": "纯前端插件不包含 extraConfig.apiBaseUrl 字段",

  "id": "my-plugin",
  "name": "我的插件",
  "nameI18n": {
    "zh-CN": "我的插件",
    "zh-TW": "我的外掛",
    "en-US": "My Plugin",
    "ja-JP": "マイプラグイン",
    "th-TH": "ปลั๊กอินของฉัน"
  },
  "description": "插件描述",
  "url": "https://my-plugin.plugins.xrugc.com/",
  "icon": "Document",
  "group": "tools",
  "enabled": true,
  "order": 10,
  "allowedOrigin": "https://my-plugin.plugins.xrugc.com",
  "version": "1.0.0"
}
