# 服务端口
PORT=8087

# ========== 数据库配置 ==========
# MySQL 主机地址
DB_HOST=localhost
# MySQL 端口
DB_PORT=3306
# 数据库名称
DB_NAME=ai_3d_generator
# 数据库用户名
DB_USER=root
# 数据库密码
DB_PASSWORD=

# ========== 主后端 API 配置 ==========
# 主后端 API 地址（用于调用 Plugin Auth API 验证身份和权限）
MAIN_API_URL=http://localhost:8081

# ========== 加密配置 ==========
# AES-256-GCM 加密密钥（必须为 64 位十六进制字符 / 32 字节）
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRYPTO_KEY=
