# 服务端口
PORT=8087

# ========== 数据库配置 ==========
# MySQL 主机地址
DB_HOST=localhost
# MySQL 端口
DB_PORT=3306
# 数据库名称
DB_NAME=ai_3d_generator
# 数据库用户名
DB_USER=root
# 数据库密码
DB_PASSWORD=

# ========== 主系统代理配置 ==========
# 插件鉴权代理（推荐，与前端 pluginApi / /api-config 使用同一套 APP_CONFIG_n 配置）
# 可填 system-admin backend 根地址，如 http://localhost:8088
APP_CONFIG_1_URL=http://localhost:8088
APP_CONFIG_1_WEIGHT=100
# APP_CONFIG_2_URL=http://localhost:8089
# APP_CONFIG_2_WEIGHT=50

# 主系统业务代理（命名预留，对应前端 mainApi / /api）
# 当前后端尚未直接使用；未配置时默认回退到 MAIN_API_URL
MAIN_BUSINESS_PROXY_URL=http://localhost:8081

# 兼容旧配置：单地址插件鉴权代理名
# 未使用 APP_CONFIG_n_URL 时才会回退读取
PLUGIN_AUTH_PROXY_URL=http://localhost:8088

# 兼容旧配置：更早的插件鉴权代理名
# 未使用 APP_CONFIG_n_URL 和 PLUGIN_AUTH_PROXY_URL 时才会回退读取
SYSTEM_ADMIN_API_URL=http://localhost:8088

# 兼容旧配置：主后端 API 根地址
MAIN_API_URL=http://localhost:8081

# ========== Tripo3D 模型版本 ==========
# 可选值: P1-20260311, v3.1-20260211, v3.0-20250812, v2.5-20250123, v2.0-20240919
# 默认: P1-20260311
# TRIPO_MODEL_VERSION=P1-20260311

# ========== 加密配置 ==========
# AES-256-GCM 加密密钥（必须为 64 位十六进制字符 / 32 字节）
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRYPTO_KEY=

# ========== PrepareToken 配置 ==========
# 前端直调模式的 PrepareToken JWT 密钥（需与 JWT_SECRET 分开）
PREPARE_TOKEN_SECRET=
